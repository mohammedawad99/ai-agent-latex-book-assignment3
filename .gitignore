# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
*.egg
develop-eggs/
.installed.cfg

# ---------------------------------------------------------------------------
# Virtual environments / uv
# ---------------------------------------------------------------------------
.venv/
venv/
env/
ENV/
.python-version
# uv keeps uv.lock under version control; only ignore its caches
.uv/
.uv-cache/

# ---------------------------------------------------------------------------
# Testing / coverage / type & lint caches
# ---------------------------------------------------------------------------
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.nox/
.cache/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover

# ---------------------------------------------------------------------------
# LaTeX build artifacts
# (keep .tex/.bib/.cls/.sty sources and the final submitted PDF)
# ---------------------------------------------------------------------------
*.aux
*.bbl
*.bcf
*.blg
*.fdb_latexmk
*.fls
*.lof
*.log
*.lot
*.out
*.toc
*.synctex.gz
*.run.xml
*.nav
*.snm
*.vrb
*.idx
*.ind
*.ilg
*.dvi
*.xdv

# ---------------------------------------------------------------------------
# Environment / secrets
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example
*.key
secrets.*

# ---------------------------------------------------------------------------
# Logs / temporary files
# ---------------------------------------------------------------------------
*.log
*.tmp
*.temp
tmp/
temp/

# ---------------------------------------------------------------------------
# OS files
# ---------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# ---------------------------------------------------------------------------
# IDE / editor
# ---------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# ---------------------------------------------------------------------------
# Evidence / reproducibility: results/ holds committed run evidence.
# Re-include it even though *.log and the LaTeX *.log rule above are broad.
# ---------------------------------------------------------------------------
!results/
!results/**

# ---------------------------------------------------------------------------
# Keep tracked: source, docs, latex sources, and final deliverables.
# Do NOT add docs/, src/, latex_project/ sources, or results/final_pdf/*.pdf here.
# ---------------------------------------------------------------------------
