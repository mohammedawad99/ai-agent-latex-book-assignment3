# Example environment configuration for ai-agent-latex-book-assignment3.
#
# Copy this file to `.env` and fill in real values locally.
# NEVER commit a real `.env` or real secrets to Git. `.env` is gitignored.
# These are placeholder variable names only — no real keys belong in this file.

# Which LLM provider the CrewAI pipeline will use (decided in Stage 5; see docs/DECISIONS.md).
LLM_PROVIDER=

# The specific model name for the chosen provider.
LLM_MODEL=

# API key for the chosen provider. Keep this only in your local .env, never in Git.
# Example variable name shown; set the one matching your provider.
OPENAI_API_KEY=
